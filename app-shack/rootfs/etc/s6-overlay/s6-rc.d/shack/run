#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Community Add-on: Shack
# Starts Shack service
# ==============================================================================

# Set log level from add-on configuration (default to INFO)
export LOG_LEVEL=$(bashio::config 'log_level' 'INFO')

bashio::log.info "Starting Shack..."

# MQTT configuration - try Supervisor API first, fallback to user config
MQTT_VIA_SUPERVISOR=false
if MQTT_RESPONSE=$(curl -s --request GET \
    -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
    -H "Content-Type: application/json" \
    "${SUPERVISOR_API:-http://supervisor}/services/mqtt" 2>/dev/null); then
    MQTT_RESULT=$(echo "${MQTT_RESPONSE}" | bashio::jq '.result' 2>/dev/null) || true
    if [ "${MQTT_RESULT}" = "ok" ]; then
        MQTT_VIA_SUPERVISOR=true
    fi
fi

if [ "${MQTT_VIA_SUPERVISOR}" = "true" ]; then
    export MQTT_HOST=$(bashio::services 'mqtt' 'host')
    export MQTT_PORT=$(bashio::services 'mqtt' 'port')
    export MQTT_USERNAME=$(bashio::services 'mqtt' 'username')
    export MQTT_PASSWORD=$(bashio::services 'mqtt' 'password')
    bashio::log.info "Using MQTT credentials from Supervisor"
else
    export MQTT_HOST=$(bashio::config 'mqtt_host')
    export MQTT_PORT=$(bashio::config 'mqtt_port')
    export MQTT_USERNAME=$(bashio::config 'mqtt_username')
    export MQTT_PASSWORD=$(bashio::config 'mqtt_password')
    bashio::log.info "Using MQTT credentials from add-on config"
fi

# Create venv at /data/.venv if it doesn't exist
if [ ! -d "/data/.venv" ]; then
    bashio::log.info "Creating virtual environment at /data/.venv..."
    uv venv /data/.venv
fi

# Initialize uv cache in persistent storage on first run
if [ ! -d "/data/.cache/uv" ]; then
    bashio::log.info "Initializing uv cache in persistent storage..."
    mkdir -p /data/.cache
    cp -r ~/.cache/uv /data/.cache/
fi

# Use persistent cache and set external venv location
export UV_CACHE_DIR=/data/.cache/uv
export UV_PROJECT_ENVIRONMENT=/data/.venv

# Sync base packages using inexact mode to preserve integration packages
# --frozen: use lockfile as-is, don't update
# --inexact: keep packages not in lockfile (integration deps)
# Only sync if needed to minimize output (but more than --quiet)
cd /app || exit 1
if ! uv sync --frozen --no-dev --inexact --check 2>/dev/null; then
    bashio::log.info "Syncing base packages..."
    uv sync --frozen --no-dev --inexact
else
    bashio::log.info "Environment is up to date"
fi

exec uv run python main.py
